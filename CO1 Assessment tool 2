<!DOCTYPE html>
<html>
<head>
<title>CSS Shadows Example</title>

<style>
body{
    background-color:#f2f2f2;
    font-family:Cambria;
    text-align:center;
    margin-top:60px;
}

h1{
    color:blue;
    text-shadow:3px 3px 5px gray;
}

.box{
    width:300px;
    margin:auto;
    padding:20px;
    background:white;
    border:2px solid blue;
    box-shadow:5px 5px 10px gray;
    font-size:18px;
}
</style>

</head>

<body>

<h1>CSS Shadows Demo</h1>

<div class="box">
    This box uses <b>Box Shadow</b>.<br><br>
    The heading uses <b>Text Shadow</b>.
</div>

</body>
</html>
